# Supabase connection settings
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Admin login credentials
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-strong-password

# Secret tokens (generate with: node -e "require('crypto').randomBytes(32).toString('hex')" )
ADMIN_TOKEN=your-random-admin-token
TOKEN_SECRET=your-random-token-secret

# Optional alternative key name for non-production setups
# SUPABASE_KEY=your-supabase-anon-key
